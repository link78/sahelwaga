# ---------------------------------------------------------------------------
# MedSupply Import & Distribution LLC Portal — example environment variables
# Copy to `.env` (root) and per-app `.env.local` as needed.
# ---------------------------------------------------------------------------

# --- Database (Postgres) ---------------------------------------------------
DATABASE_URL=******localhost:5432/sahelwaga?schema=public

# --- API -------------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# Comma-separated list of allowed CORS origins for the API
# If accessing from an external IP, add it here (e.g. http://66.94.119.88:3000)
CORS_ORIGINS=http://localhost:3000

# JWT (use a long random string in prod)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-xxxxxxxxxx
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-xxxxxxxxx
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Auth cookies / CSRF --------------------------------------------------
# Set AUTH_COOKIE_SECURE=true in production (requires HTTPS). SameSite=lax is
# the safe default for first-party app + API. Use `none` only when the API and
# web app live on different sites; pair with AUTH_COOKIE_SECURE=true.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_DOMAIN=.sahelwaga.com

# Express `trust proxy` setting. Set when the API runs behind a reverse
# proxy (nginx, Caddy, Cloudflare, load balancer) so that req.ip and the
# X-Forwarded-For / X-Forwarded-Proto headers are honoured (required by
# express-rate-limit). Accepts the same values as Express:
#   - "true" / "false"
#   - an integer hop count (e.g. "1" for a single proxy in front)
#   - a comma-separated list of trusted IPs/subnets, or a preset like
#     "loopback", "linklocal", "uniquelocal"
# Most single-proxy deployments want "1".
TRUST_PROXY=false

# --- Redis (BullMQ background jobs) ---------------------------------------
REDIS_URL=redis://localhost:6379

# --- S3 / MinIO (document storage) ----------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sahelwaga-docs
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Email (Mailhog in dev) -----------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MedSupply <no-reply@sahelpharma.local>"

# --- Web (Next.js) --------------------------------------------------------
# Public API URL: baked into the browser bundle at build time. Set this to
# the externally reachable API hostname (e.g. https://api.example.com).
NEXT_PUBLIC_API_URL=http://localhost:4000
# Optional server-only API URL used by Next.js Server Components / route
# handlers when fetching the API from within the Node process. Set this to
# a private/internal address (e.g. http://localhost:4000 or a Docker
# service name) when the public URL is HTTPS / not reachable from the
# server itself. Falls back to NEXT_PUBLIC_API_URL when unset.
# API_INTERNAL_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-nextauth-secret-min-32-chars-xxxxxxxxxx
