# ---------------------------------------------------------------------------
# Sahel Pharma Group Portal — example environment variables
# Copy to `.env` (root) and per-app `.env.local` as needed.
# ---------------------------------------------------------------------------

# --- Database (Postgres) ---------------------------------------------------
DATABASE_URL=******localhost:5432/sahelwaga?schema=public

# --- API -------------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# Comma-separated list of allowed CORS origins for the API
CORS_ORIGINS=http://localhost:3000

# JWT (use a long random string in prod)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-xxxxxxxxxx
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-xxxxxxxxx
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Redis (BullMQ background jobs) ---------------------------------------
REDIS_URL=redis://localhost:6379

# --- S3 / MinIO (document storage) ----------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sahelwaga-docs
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Email (Mailhog in dev) -----------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Sahel Pharma <no-reply@sahelpharma.local>"

# --- Web (Next.js) --------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-nextauth-secret-min-32-chars-xxxxxxxxxx
